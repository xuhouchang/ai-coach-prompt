{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Coach learner profile v2",
  "type": "object",
  "required": [
    "version",
    "profile",
    "learning_state",
    "learning_material",
    "updated_at"
  ],
  "properties": {
    "version": {
      "const": 2
    },
    "profile": {
      "type": "object",
      "properties": {
        "ai_fluency": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 80
        },
        "role": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 120
        },
        "industry": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 120
        },
        "learning_goal": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 800
        },
        "recommended_task_types": {
          "type": "array",
          "maxItems": 6,
          "uniqueItems": true,
          "items": {
            "enum": [
              "extraction_task",
              "comparison_task",
              "evaluation_task",
              "generation_task",
              "rewriting_task",
              "multistep_task"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "learning_state": {
      "type": "object",
      "properties": {
        "current_state": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 120
        },
        "interaction_mode": {
          "const": "text_nonblocking"
        },
        "current_section": {
          "type": ["string", "null"],
          "maxLength": 120
        },
        "current_page": {
          "type": ["string", "null"],
          "maxLength": 160
        },
        "awaiting_user_action": {
          "type": "boolean"
        },
        "allowed_actions": {
          "type": "array",
          "maxItems": 6,
          "uniqueItems": true,
          "items": {
            "enum": ["continue", "explain", "example", "back_to_catalog", "exit", "submit"]
          }
        },
        "completed_intro_pages": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "maxLength": 80
          }
        },
        "learned_task_types": {
          "type": "array",
          "maxItems": 6,
          "uniqueItems": true,
          "items": {
            "enum": [
              "extraction_task",
              "comparison_task",
              "evaluation_task",
              "generation_task",
              "rewriting_task",
              "multistep_task"
            ]
          }
        },
        "current_task_type": {
          "anyOf": [
            {
              "enum": [
                "extraction_task",
                "comparison_task",
                "evaluation_task",
                "generation_task",
                "rewriting_task",
                "multistep_task"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "current_node_index": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8
        },
        "current_scenario_context": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 3000
        },
        "current_node_answers": {
          "type": "object",
          "maxProperties": 12,
          "patternProperties": {
            "^[a-z][a-z0-9_]{0,63}$": {
              "type": "string",
              "maxLength": 5000
            }
          },
          "additionalProperties": false
        },
        "type_drafts": {
          "type": "array",
          "maxItems": 24,
          "items": {
            "type": "object",
            "required": [
              "task_type",
              "answers"
            ],
            "properties": {
              "task_type": {
                "enum": [
                  "extraction_task",
                  "comparison_task",
                  "evaluation_task",
                  "generation_task",
                  "rewriting_task",
                  "multistep_task"
                ]
              },
              "scenario_context": {
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 3000
              },
              "answers": {
                "type": "object",
                "maxProperties": 12,
                "patternProperties": {
                  "^[a-z][a-z0-9_]{0,63}$": {
                    "type": "string",
                    "maxLength": 5000
                  }
                },
                "additionalProperties": false
              },
              "skipped_nodes": {
                "type": "array",
                "maxItems": 12,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "maxLength": 64
                }
              },
              "assembled_prompt": {
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 30000
              },
              "completed_at": {
                "type": [
                  "string",
                  "null"
                ],
                "maxLength": 40
              }
            },
            "additionalProperties": false
          }
        },
        "suspended_learning_stack": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "pending_test_prompt": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 20000
        },
        "capture_mode": {
          "type": "boolean"
        },
        "assessment_history": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    },
    "learning_material": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "required": [
          "kind",
          "content",
          "created_at",
          "sha256"
        ],
        "properties": {
          "kind": {
            "const": "prompt"
          },
          "content": {
            "type": "string",
            "maxLength": 20000
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "additionalProperties": false
      }
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
